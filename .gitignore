__pycache__/
*.pyc
venv/
.venv/
data/*/sameinad.xlsx
gas/.clasp.json
**/~$*
*.xlsx

# Real student data (names, kennitala, phone numbers) - never commit these.
# Only data/example_input.json (root of data/, not data/<case>/) is the
# checked-in, anonymized stand-in - this pattern only matches one level
# under data/, so it's untouched.
data/*/input*.json
data/*/output*.json

# docs/<year>/ holds real historical xlsx inputs and everything generated
# from them (input.json, output.json, recreated mrs_radad_*.xlsx) - no
# anonymized stand-in exists for these, so the whole tree stays out of git.
/docs/
